OPENAI_API_KEY=your_openai_key_here
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
TWITTER_EMAIL=your_twitter_email
TWITTER_2FA_SECRET=your_2fa_secret
POST_IMMEDIATELY=true
ENABLE_ACTION_PROCESSING=true
MAX_ACTIONS_PROCESSING=10
POST_INTERVAL_MAX=180
POST_INTERVAL_MIN=90
TWITTER_SPACES_ENABLE=false
ACTION_TIMELINE_TYPE=foryou
TWITTER_POLL_INTERVAL=120
TAVILY_API_KEY=your_tavily_key
COINMARKETCAP_API_KEY=your_coinmarketcap_key
# CoinGecko: use Direct API only to avoid crash-loop from mcp.api.coingecko.com (recommended on Oracle/PM2)
COINGECKO_USE_DIRECT_API_ONLY=1
COINGECKO_API_KEY=your_coingecko_pro_api_key
NODE_ENV=production